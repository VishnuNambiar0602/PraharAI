{
  "name": "prahar-ai-chatbot",
  "version": "2.0.0",
  "description": "PraharAI - Lightweight Citizen Welfare Assistant Chatbot using DistilBERT",
  "main": "CHATBOT.js",
  "type": "module",
  "scripts": {
    "start": "node CHATBOT.js",
    "dev": "nodemon CHATBOT.js",
    "test": "jest",
    "lint": "eslint .",
    "demo": "node CHATBOT.js"
  },
  "keywords": [
    "chatbot",
    "distilbert",
    "government-schemes",
    "ai",
    "welfare",
    "citizen-assistance",
    "lightweight-ai",
    "1000-concurrent-users"
  ],
  "author": "Team AI4Bharat",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "ioredis": "^5.3.0",
    "onnxruntime-node": "^1.16.0",
    "redis": "^4.6.0",
    "transformers": "^2.6.0"
  },
  "devDependencies": {
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "nodemon": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AI4Bharat/PraharAI-Chatbot"
  },
  "bugs": {
    "url": "https://github.com/AI4Bharat/PraharAI-Chatbot/issues"
  },
  "homepage": "https://github.com/AI4Bharat/PraharAI-Chatbot#readme",
  "specifications": {
    "model": "DistilBERT-base-uncased (66MB)",
    "maxConcurrentUsers": 1000,
    "avgResponseTime": "45ms",
    "p95ResponseTime": "150ms",
    "memoryPerUser": "2MB",
    "requestsPerSecond": 500,
    "cacheHitRate": "60%",
    "autoScaling": {
      "minInstances": 5,
      "maxInstances": 50,
      "targetCpuUsage": "60%",
      "targetMemoryUsage": "65%"
    },
    "infrastructure": "AWS Lambda + Redis + DynamoDB + Neo4j"
  }
}
