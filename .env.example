# Common Environment Configuration (single source of truth)

# Backend service
NODE_ENV=development
PORT=3000
MCP_PORT=3001
LOG_LEVEL=info

# Admin endpoints
ADMIN_KEY=replace-with-strong-admin-key

# JWT
JWT_SECRET=replace-with-64-char-random-hex
JWT_REFRESH_SECRET=replace-with-64-char-random-hex
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Encryption key (64 hex chars = 32 bytes)
ENCRYPTION_KEY=replace-with-64-hex-characters

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123
NEO4J_DATABASE=neo4j
NEO4J_CONNECT_RETRIES=8
NEO4J_CONNECT_RETRY_DELAY_MS=2000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# External APIs
MYSCHEME_API_URL=https://api.myscheme.gov.in
MYSCHEME_API_KEY=
GOOGLE_TRANSLATE_API_KEY=

# ML service
ML_SERVICE_URL=http://localhost:8000
ML_SERVICE_HOST=0.0.0.0
ML_SERVICE_PORT=8000
ENVIRONMENT=development
BACKEND_URL=http://localhost:3000

# Model paths (optional)
INTENT_CLASSIFIER_MODEL=models/intent_classifier.pth
USER_CLASSIFIER_MODEL=models/user_classifier.json
RECOMMENDATION_MODEL=models/recommendation_model.json

# LLM settings
LLM_PROVIDER=none
LLM_MODEL=llama3
LLM_API_KEY=
LLM_BASE_URL=

# TinyLM settings (optional)
TINYLM_MODEL_ID=sshleifer/tiny-gpt2
TINYLM_HOST=0.0.0.0
TINYLM_PORT=8001

# Nudge system
NUDGE_ENABLED=true
NUDGE_SCHEDULE_MS=21600000
NUDGE_NEW_SCHEME_BATCH_LIMIT=250
NUDGE_SEED_BATCH_LIMIT=2500
NUDGE_DEADLINE_DAYS_AHEAD=7
NUDGE_MIN_SCORE_FLOOR=70
NUDGE_NEW_SCHEME_COOLDOWN_DAYS=14

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# Cache TTL (seconds)
CACHE_TTL_SCHEMES=86400
CACHE_TTL_RECOMMENDATIONS=86400
CACHE_TTL_ELIGIBILITY=86400

# Optional classifier process settings
CLASSIFIER_MODEL_PATH=
PYTHON_PATH=python

# Frontend
REACT_APP_API_URL=http://localhost:3000
REACT_APP_WS_URL=ws://localhost:3000
APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000
