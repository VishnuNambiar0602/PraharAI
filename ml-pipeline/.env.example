# ML Pipeline Service Configuration

# Service Configuration
ML_SERVICE_HOST=0.0.0.0
ML_SERVICE_PORT=8000
ENVIRONMENT=development

# Backend API URL (for chat service to fetch schemes)
BACKEND_URL=http://localhost:3000

# Model Paths (optional, defaults to models/ directory)
INTENT_CLASSIFIER_MODEL=models/intent_classifier.pth
USER_CLASSIFIER_MODEL=models/user_classifier.json
RECOMMENDATION_MODEL=models/recommendation_model.json

# LLM Configuration (optional, for generative responses)
# Uncomment and configure one of the following:

# OpenAI
# OPENAI_API_KEY=your-api-key-here
# OPENAI_MODEL=gpt-3.5-turbo

# Gemini
# GEMINI_API_KEY=your-api-key-here
# GEMINI_MODEL=gemini-pro

# Ollama (local)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama2

# Logging
LOG_LEVEL=INFO
