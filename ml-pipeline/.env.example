# ML Pipeline service configuration

# Service
ML_SERVICE_HOST=0.0.0.0
ML_SERVICE_PORT=8000
ENVIRONMENT=development
LOG_LEVEL=INFO

# Backend API (used by chat_service)
BACKEND_URL=http://localhost:3000

# Neo4j (used by training/data extraction and optional integrations)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123

# Model paths (optional)
INTENT_CLASSIFIER_MODEL=models/intent_classifier.pth
USER_CLASSIFIER_MODEL=models/user_classifier.json
RECOMMENDATION_MODEL=models/recommendation_model.json

# Provider-agnostic LLM settings (used by src/llm_service.py)
# Supported providers: none | ollama | openai | gemini
LLM_PROVIDER=none
LLM_MODEL=llama3
LLM_API_KEY=
LLM_BASE_URL=
