# =============================================================================
# PraharAI Production Environment Configuration
# =============================================================================
# Copy this file to .env.production and fill in all values.
# NEVER commit the actual .env.production file to version control.
# =============================================================================

# --- Deployment ---
NODE_ENV=production
ENVIRONMENT=production

# --- Backend ---
PORT=3000
LOG_LEVEL=info
ADMIN_KEY=CHANGE_ME_admin_key_here
CORS_ORIGINS=https://your-frontend-domain.com

# --- JWT (generate with: openssl rand -hex 32) ---
JWT_SECRET=CHANGE_ME_64_hex_chars
JWT_REFRESH_SECRET=CHANGE_ME_64_hex_chars_different
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- Encryption (generate with: openssl rand -hex 32) ---
ENCRYPTION_KEY=CHANGE_ME_64_hex_chars

# --- Neo4j ---
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME_neo4j_password
NEO4J_DATABASE=neo4j
NEO4J_CONNECT_RETRIES=8
NEO4J_CONNECT_RETRY_DELAY_MS=2000

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_password

# --- ML Service ---
ML_SERVICE_URL=http://ml:8000
ML_SERVICE_HOST=0.0.0.0
ML_SERVICE_PORT=8000
BACKEND_URL=http://backend:3000
ML_CB_FAILURES=3
ML_CB_OPEN_MS=30000

# --- External APIs ---
MYSCHEME_API_URL=https://api.myscheme.gov.in
MYSCHEME_API_KEY=
GOOGLE_TRANSLATE_API_KEY=

# --- Optional: LLM Provider ---
LLM_PROVIDER=none
LLM_MODEL=
LLM_API_KEY=
LLM_BASE_URL=

# --- Optional: Gemini (frontend) ---
GEMINI_API_KEY=

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# --- Chat Runtime Limits ---
CHAT_INPUT_TOKEN_LIMIT=500
CHAT_RESPONSE_TIMEOUT_MS=12000
CHAT_CONTEXT_TOKEN_BUDGET=1800
CHAT_SUMMARY_TOKEN_BUDGET=400
CHAT_MESSAGE_TOKEN_LIMIT=400
CHAT_OUTPUT_CHAR_LIMIT=3500

# --- Scheme Sync/Enrichment Tuning ---
SCHEME_SYNC_RESUME_DELAY_MS=300000
SCHEME_ENRICH_BATCH_SIZE=120
SCHEME_SYNC_PAUSE_FAILURE_RATIO=0.7
SCHEME_SYNC_PAUSE_MIN_BATCH_SIZE=50
SCHEME_ENRICH_MAX_RETRIES=3
SCHEME_ENRICH_RETRY_BASE_MS=400
SCHEME_ENRICH_CONCURRENCY=3
SCHEME_ENRICH_MIN_REQUEST_GAP_MS=220
SCHEME_ENRICH_RATE_LIMIT_COOLDOWN_MS=3000
SCHEME_ENRICH_MAX_RATE_LIMIT_COOLDOWN_MS=30000

# --- Nudge System ---
NUDGE_ENABLED=true
NUDGE_SCHEDULE_MS=21600000
NUDGE_NEW_SCHEME_BATCH_LIMIT=250
NUDGE_SEED_BATCH_LIMIT=2500
NUDGE_DEADLINE_DAYS_AHEAD=7
NUDGE_MIN_SCORE_FLOOR=70
NUDGE_NEW_SCHEME_COOLDOWN_DAYS=14

# --- GP Auto-Seed (LGD villages) ---
AUTO_SEED_GP_ON_STARTUP=true
DATA_GOV_IN_API_KEY=
LGD_GP_RESOURCE_ID=f17a1608-5f10-4610-bb50-a63c80d83974

# --- Model Paths ---
INTENT_CLASSIFIER_MODEL=models/intent_classifier.pth
USER_CLASSIFIER_MODEL=models/user_classifier.json
RECOMMENDATION_MODEL=models/recommendation_model.json
